# Day One — environment variables (copy to .env and fill in)
# .env is gitignored. Never commit real keys.

# ----- Gemini -----
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model tiers (override here if you want to A/B different models)
GEMINI_FAST_MODEL=gemini-2.5-flash
# strong tier: free tier projects often have 0-quota on gemini-2.5-pro;
# default to flash + thinking-on (set by the strong tier in llm.py).
# Upgrade to gemini-2.5-pro once billing is enabled if you want better scenarios.
GEMINI_STRONG_MODEL=gemini-2.5-flash

# ----- Backend -----
DATABASE_URL=sqlite:///./dayone.db
CORS_ORIGINS=http://localhost:5173

# Session pacing knobs (Phase 3 will read these)
# Turns of candidate→cast exchange before the twist fires
TWIST_TRIGGER_TURN=4
# Hard ceiling on session duration in seconds (UI countdown)
SESSION_MAX_SECONDS=1800
